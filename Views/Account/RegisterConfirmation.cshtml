@{
    ViewData["Title"] = "Registration Successful";
}

<div class="container mt-5 text-center">
    <div class="card shadow p-5">
        <i class="bi bi-envelope-check text-success" style="font-size: 4rem;"></i>
        <h2 class="mt-3">Check Your Email</h2>
        <p class="lead">
            We have sent a confirmation link to <strong>@ViewBag.Email</strong>.
        </p>
        <p>
            Please check your inbox (and spam folder) and click the link to activate your library account.
        </p>
        <hr />
        <p class="text-muted">
            Once confirmed, you will be able to log in.
        </p>
        <a href="/Login" class="btn btn-primary mt-3">Back to Login</a>
    </div>
</div>