@model IReadOnlyList<Library_Management_system.Models.LibraryEvent>
@{
    ViewBag.Title = "Manage Events";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/ManageEvent.css" asp-append-version="true" />
}

<div class="dashboard-page container-fluid event-page" id="manageEventPage">
    <header class="page-header">
        <div>
            <h1 class="page-title">Event Management</h1>
            <p class="page-subtitle">Plan and manage library events, schedules, and locations.</p>
        </div>

        <button type="button" class="add-event-btn" data-bs-toggle="modal" data-bs-target="#addEventModal">
            <i class="bi bi-plus-circle-fill"></i>
            <span>Add Event</span>
        </button>
    </header>

    <section class="table-container">
        <div class="table-responsive">
            <table class="table event-table">
                <thead>
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">Image</th>
                        <th scope="col">Event Name</th>
                        <th scope="col">Description</th>
                        <th scope="col">Start Date</th>
                        <th scope="col">End Date</th>
                        <th scope="col">Location</th>
                        <th scope="col">Created By</th>
                        <th scope="col">Created Date</th>
                        <th scope="col">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var rowNo = 0;
                        foreach (var item in Model)
                        {
                            rowNo++;
                            var eventImage = string.IsNullOrWhiteSpace(item.ImageUrl)
                                ? Url.Content("~/images/User/Book/book2.png")
                                : Url.Content(item.ImageUrl);
                            var shortDescription = item.Description.Length > 70
                                ? $"{item.Description[..70]}..."
                                : item.Description;

                            <tr data-event-id="@item.Id"
                                data-event-name="@item.Name"
                                data-description="@item.Description"
                                data-location="@item.Location"
                                data-start-date="@item.StartDate.ToString("yyyy-MM-dd")"
                                data-end-date="@item.EndDate.ToString("yyyy-MM-dd")"
                                data-image-url="@eventImage">
                                <th scope="row">@rowNo</th>
                                <td>
                                    <img class="event-cover" src="@eventImage" alt="Event image" />
                                </td>
                                <td>@item.Name</td>
                                <td>@shortDescription</td>
                                <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.Location</td>
                                <td>@(string.IsNullOrWhiteSpace(item.CreatedBy) ? "System" : item.CreatedBy)</td>
                                <td>@item.CreatedDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <div class="action-container">
                                        <button class="edit-event-btn" type="button" data-bs-toggle="modal" data-bs-target="#editEventModal" aria-label="Edit event">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="delete-event-btn" type="button" data-event-id="@item.Id" aria-label="Delete event">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">No events found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <div class="modal fade" id="addEventModal" tabindex="-1" aria-labelledby="addEventModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addEventModalLabel">Add Event</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="addEventForm">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="eventNameInput">Event Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="eventNameInput" placeholder="eg. Book Fair 2026" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="locationInput">Location <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="locationInput" placeholder="eg. Main Library Hall" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="startDateInput">Start Date <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" id="startDateInput" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="endDateInput">End Date <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" id="endDateInput" required />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label" for="eventImageInput">Event Image</label>
                                <input type="file" class="form-control" id="eventImageInput" accept="image/*" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label" for="descriptionTextarea">Description <span class="text-danger">*</span></label>
                                <textarea class="form-control" id="descriptionTextarea" rows="3" placeholder="Enter event description" required></textarea>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success" id="addEventBtn">Add Event</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editEventModal" tabindex="-1" aria-labelledby="editEventModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editEventModalLabel">Edit Event</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="editEventForm">
                        <input type="hidden" id="editEventIdInput" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="edit-eventNameInput">Event Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="edit-eventNameInput" placeholder="eg. Book Fair 2026" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="edit-locationInput">Location <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="edit-locationInput" placeholder="eg. Main Library Hall" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="edit-startDateInput">Start Date <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" id="edit-startDateInput" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="edit-endDateInput">End Date <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" id="edit-endDateInput" required />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label" for="edit-eventImageInput">Event Image</label>
                                <input type="file" class="form-control" id="edit-eventImageInput" accept="image/*" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label" for="edit-descriptionTextarea">Description <span class="text-danger">*</span></label>
                                <textarea class="form-control" id="edit-descriptionTextarea" rows="3" placeholder="Enter event description" required></textarea>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success" id="updateEventBtn">Update Event</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/ManageEvent.js" asp-append-version="true"></script>
}
