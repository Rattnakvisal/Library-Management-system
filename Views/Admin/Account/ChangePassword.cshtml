@model Library_Management_system.Models.Admin.AdminChangePasswordInput
@{
    ViewBag.Title = "Change Password";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/AdminAccount.css" asp-append-version="true" />
}

<div class="setting-shell">
    <section class="setting-card">
        <header class="setting-title-wrap">
            <h1 class="setting-title">Setting</h1>
        </header>

        <nav class="setting-tabs">
            <a class="tab-item tab-link" asp-controller="AdminAccount" asp-action="Profile">Edit Profile</a>
            <button type="button" class="tab-item active">Security</button>
        </nav>

        @if (TempData["PasswordSuccess"] is string success && !string.IsNullOrWhiteSpace(success))
        {
            <div class="alert alert-success mt-3 mb-0" role="alert">@success</div>
        }

        <div class="setting-body setting-body-security">
            <form method="post" asp-controller="AdminAccount" asp-action="ChangePassword" novalidate
                  class="setting-form security-form">
                <h2 class="section-caption section-caption-first">Change Password</h2>
                <p class="security-help">Use your current password to set a new secure password.</p>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 mb-3"></div>

                <div class="field-wrap">
                    <label asp-for="CurrentPassword" class="form-label"></label>
                    <input asp-for="CurrentPassword" class="form-control setting-input"
                           autocomplete="current-password" />
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>

                <div class="field-wrap">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" class="form-control setting-input" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="field-wrap">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control setting-input" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-save-profile">Update Password</button>
                </div>
            </form>

            <aside class="security-side-panel">
                <h3>Password Rules</h3>
                <ul class="security-rules">
                    <li>At least 6 characters</li>
                    <li>At least one uppercase letter</li>
                    <li>At least one lowercase letter</li>
                    <li>At least one number</li>
                </ul>
            </aside>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
