@{
    ViewBag.Title = "Manage Report";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/Reports.css" asp-append-version="true" />
}

<div class="dashboard-page container-fluid" data-report-url="@Url.Action("Data", "ManageReport")">
    <div class="reports-page">
        <header class="page-header">
            <h1 class="page-title">Reports Management</h1>
            <p class="page-subtitle">Generate and view various reports for library management.</p>
        </header>

        <div class="row mb-3 align-items-center controls-row">
            <div class="col-md-10">
                <div class="custom-select" id="reportTypeSelect">
                    <button class="select-btn" id="reportTypeBtn" type="button">Borrowing Report <span class="caret">▾</span></button>
                    <ul class="options">
                        <li data-value="borrowing">Borrowing Report</li>
                        <li data-value="returns">Return Books Report</li>
                        <li data-value="most-borrowed">Most Borrowed Books Report</li>
                        <li data-value="fine-collection">Fine Collection Report</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-2 text-end">
                <div class="export-select" id="exportTypeSelect">
                    <button class="select-btn" id="exportTypeBtn" type="button">Export Type <span class="caret">▾</span></button>
                    <ul class="options right">
                        <li data-value="excel">Export as Excel</li>
                        <li data-value="pdf">Export as PDF</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="row mb-4 date-row">
            <div class="col-md-2">
                <label class="form-label" for="fromDate">From Date</label>
                <input type="date" class="form-control" id="fromDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label" for="toDate">To Date</label>
                <input type="date" class="form-control" id="toDate" />
            </div>
        </div>

        <div class="report-table-wrapper">
            <table class="table report-table">
                <thead>
                    <tr>
                        <th>Borrow ID</th>
                        <th>Book Title</th>
                        <th>Borrow Date</th>
                        <th>Due Date</th>
                        <th>Duration / 1 week</th>
                        <th class="text-end">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Loading report data...</td>
                    </tr>
                </tbody>
            </table>

            <div class="pagination-wrapper">
                <div class="report-meta" id="reportMeta"></div>
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-end" id="reportPagination"></ul>
                </nav>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/Reports.js" asp-append-version="true"></script>
}

