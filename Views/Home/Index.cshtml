@model Library_Management_system.Models.HomeViewModel
@{
    ViewData["Title"] = "Home Page";
}

<!-- Slide Show -->
<div id="homePage" class="container px-0 home-page">
    <div id="heroCarousel" class="carousel slide mx-2 home-hero" data-bs-ride="carousel">

        <div class="carousel-indicators custom-indicators">
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"
                    aria-current="true"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3"></button>
        </div>

        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="/images/User/Slideshow/img_library1.jpg" class="d-block w-100 main-slider-img" alt="slide 1">
            </div>
            <div class="carousel-item">
                <img src="/images/User/Slideshow/img_library2.jpg" class="d-block w-100 main-slider-img" alt="Slide 2">
            </div>
            <div class="carousel-item">
                <img src="/images/User/Slideshow/img_library2.jpg" class="d-block w-100 main-slider-img" alt="Slide 3">
            </div>
            <div class="carousel-item">
                <img src="/images/User/Slideshow/img_library2.jpg" class="d-block w-100 main-slider-img" alt="Slide 4">
            </div>
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
        </button>
    </div>
    <!-- slide show end -->
    <!-- categories -->
    <section class="container-fluid mt-4 home-section home-category-section">
        <div class="d-flex justify-content-between align-items-center mb-4 home-section-head">
            <h3 class="fw-bold text-navy">Book Categories</h3>
            <a asp-controller="Home" asp-action="Book" class="btn btn-outline-secondary btn-sm">
                Explore more
            </a>
        </div>
        <div class="row g-4 home-category-row">
            @foreach (var category in Model.Categories)
            {
                <div class="col-12 col-sm-6 col-lg-4 home-category-col">
                    <a asp-controller="Home" asp-action="Book" asp-route-category="@category.Name"
                           class="text-decoration-none">
                        <div class="card book-card shadow-sm h-100">
                            <img src="@(string.IsNullOrWhiteSpace(category.ImageUrl) ? "/images/User/Book/general.jpg" : category.ImageUrl)"
                                 class="card-img-top custom-card-img" alt="@category.Name">
                            <div class="card-body py-2">
                                <h6 class="mb-0">@category.Name.ToUpper()</h6>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </section>
    <!-- categories end -->
    <!-- Top Trending Books -->
    <section class="container-fluid mt-4 home-section">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold text-navy">Top Trending</h3>
        </div>

        <div class="d-flex flex-nowrap overflow-auto gap-3 pb-3 custom-scrollbar top-trending-scroll">
            @foreach (var book in Model.TrendingBooks)
            {
                <div class="top-trending-item flex-shrink-0">
                    <div class="card book-card border-0 shadow-sm h-100">
                        <div class="card-img-wrapper p-2">
                            <a asp-controller="Home" asp-action="BookDetail" asp-route-id="@book.Id"
                                   class="text-decoration-none">
                                <img src="@(string.IsNullOrWhiteSpace(book.ImageUrl) ? "/images/User/Book/book2.png" : book.ImageUrl)"
                                     class="card-img-top rounded" alt="@book.Title" height="200">
                            </a>
                        </div>
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="category-text small fw-bold">@(string.IsNullOrWhiteSpace(book.CategoryName) ?
                                                                                                                                                                                                                                                                                                                                                                                                                                            "Professional and Technical" : book.CategoryName)</span>
                                    <button class="btn p-0 border-0 wishlist-btn text-secondary" data-id="@book.Id">
                                        <i class="fa-solid fa-heart"></i>
                                    </button>
                                </div>
                                <h6 class="book-title mb-1 small fw-bold">
                                    <a asp-controller="Home" asp-action="BookDetail" asp-route-id="@book.Id"
                                           class="text-decoration-none text-dark">
                                        @book.Title
                                    </a>
                                </h6>
                                <p class="author-text mb-3 small italic">@book.Author</p>
                                <div class="text-end star-rating text-warning small">
                                    @for (int i = 0; i < Math.Clamp(book.Rating, 0, 5); i++)
                                    {
                                        <i class="fa-solid fa-star"></i>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
        <!-- Top Trending Books End -->
        <!-- author by genre section -->
        <section class="container-fluid mt-4 home-section">
            <h3 class="fw-bold mb-4 text-navy">Author by Genre</h3>

            <div class="d-flex custom-scrollbar pb-3" style="gap: 1rem;">
                @foreach (var genre in Model.CategoryGenres)
                {
                    <div class="genre-card-wrapper flex-shrink-0">
                        <a asp-controller="Home" asp-action="Book" asp-route-category="@genre.Name"
                               class="text-decoration-none">
                            <div class="card border-0 rounded-4 overflow-hidden position-relative genre-card shadow-sm">
                                <img src="@(string.IsNullOrWhiteSpace(genre.ImageUrl) ? "/images/User/Book/science-fiction.jpg" : genre.ImageUrl)"
                                     class="card-img" alt="@genre.Name">
                                <div class="genre-overlay d-flex align-items-end p-3">
                                    <h5 class="text-white fw-bold mb-0">@genre.Name</h5>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </section>
        <!-- author by genre section end -->
        <!-- New arrival section -->
        <section class="container-fluid mt-4 home-section">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold text-navy">New Arrival</h3>
                <a asp-controller="Home" asp-action="Book" class="btn btn-outline-secondary btn-sm">Explore more</a>
            </div>

            <div class="d-flex flex-nowrap overflow-auto gap-3 pb-3 custom-scrollbar top-trending-scroll">
                @foreach (var book in Model.NewArrivalBooks)
                {
                    <div class="top-trending-item flex-shrink-0">
                        <div class="card book-card border-0 shadow-sm h-100">
                            <div class="card-img-wrapper p-2">
                                <a asp-controller="Home" asp-action="BookDetail" asp-route-id="@book.Id"
                                       class="text-decoration-none">
                                    <img src="@(string.IsNullOrWhiteSpace(book.ImageUrl) ? "/images/User/Book/book2.png" : book.ImageUrl)"
                                         class="card-img-top rounded" alt="@book.Title" height="200">
                                </a>
                            </div>

                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="category-text small fw-bold">@(string.IsNullOrWhiteSpace(book.CategoryName) ?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "Professional and Technical" : book.CategoryName)</span>
                                        <button class="btn p-0 border-0 wishlist-btn text-secondary" data-id="@book.Id">
                                            <i class="fa-solid fa-heart"></i>
                                        </button>
                                    </div>

                                    <h6 class="book-title mb-1 small fw-bold">
                                        <a asp-controller="Home" asp-action="BookDetail" asp-route-id="@book.Id"
                                               class="text-decoration-none text-dark">
                                            @book.Title
                                        </a>
                                    </h6>

                                    <p class="author-text mb-3 small italic">@book.Author</p>

                                    <div class="text-end star-rating text-warning small">
                                        @for (int i = 0; i < Math.Clamp(book.Rating, 0, 5); i++)
                                        {
                                            <i class="fa-solid fa-star"></i>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
            <!-- New arrival section end -->

            @await Html.PartialAsync("_StaticChatbot")
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const sliders = document.querySelectorAll(".custom-scrollbar");

                sliders.forEach((slider) => {
                    slider.addEventListener("wheel", function (e) {
                        const hasHorizontalIntent = Math.abs(e.deltaX) > Math.abs(e.deltaY);
                        const useVerticalAsHorizontal = e.shiftKey && Math.abs(e.deltaY) > 0;

                        if (!hasHorizontalIntent && !useVerticalAsHorizontal) {
                            return;
                        }

                        const maxScrollLeft = slider.scrollWidth - slider.clientWidth;
                        if (maxScrollLeft <= 0) {
                            return;
                        }

                        const delta = hasHorizontalIntent ? e.deltaX : e.deltaY;
                        const nextScrollLeft = slider.scrollLeft + delta;
                        const clampedScrollLeft = Math.max(0, Math.min(maxScrollLeft, nextScrollLeft));

                        if (clampedScrollLeft === slider.scrollLeft) {
                            return;
                        }

                        e.preventDefault();
                        slider.scrollLeft = clampedScrollLeft;
                    }, { passive: false });
                });
            });
        </script>

        @section Scripts {
            <script src="~/js/users/Home.js" asp-append-version="true"></script>
        }
