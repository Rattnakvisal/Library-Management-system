@using System.Globalization
@model Library_Management_system.Models.BookDetailViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var book = Model.Book;
    ViewData["Title"] = "Book detail";
    ViewData["BreadcrumbCurrent"] = string.IsNullOrWhiteSpace(book.Title) ? "Book detail" : book.Title;
    var imagePath = string.IsNullOrWhiteSpace(book.ImageUrl)
        ? Url.Content("~/images/User/Book/book2.png")
        : Url.Content(book.ImageUrl);
    var rating = Math.Clamp(book.Rating, 0, 5);
    var publishYear = book.Year > 0
        ? book.Year.ToString(CultureInfo.InvariantCulture)
        : book.CreatedDate?.Year.ToString(CultureInfo.InvariantCulture) ?? "N/A";
    var totalPages = book.Pages > 0 ? book.Pages.ToString(CultureInfo.InvariantCulture) : "N/A";
    var bookCode = string.IsNullOrWhiteSpace(book.BookCode) ? $"A{book.Id:0000}" : book.BookCode;
    var description = string.IsNullOrWhiteSpace(book.Description)
        ? "No summary is available for this book yet."
        : book.Description;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var shareUrl = Url.Action("BookDetail", "Home", new { id = book.Id }) ?? $"/book/{book.Id}";
}

<div id="bookDetailPage" class="page-wrap book-detail-page">
    <div class="row g-4 g-lg-5 align-items-start detail-top">
        <div class="col-12 col-sm-5 col-lg-4 detail-media">
            <img src="@imagePath" class="main-img cover-sm detail-cover" alt="@book.Title">
        </div>

        <div class="col-12 col-sm-7 col-lg-8 detail-content">
            <div class="detail-header d-flex justify-content-between align-items-start gap-3">
                <div>
                    <h1 class="book-title">@book.Title</h1>
                    <p class="author-name">Author: @book.Author</p>
                </div>

                <div class="rate-box">
                    <div class="text-end star-rating text-warning small">
                        @for (var i = 0; i < 5; i++)
                        {
                            if (i < rating)
                            {
                                <i class="fa-solid fa-star"></i>
                            }
                            else
                            {
                                <i class="fa-regular fa-star"></i>
                            }
                        }
                    </div>
                    <div class="rate-score">@rating/5</div>
                    <div class="rate-text">Rate this book</div>
                </div>
            </div>

            <p class="desc-text">
                @description
            </p>

            @if (TempData["BookReviewSuccess"] is string reviewSuccess && !string.IsNullOrWhiteSpace(reviewSuccess))
            {
                <div class="alert alert-success py-2 px-3 mb-3" role="alert">@reviewSuccess</div>
            }
            @if (TempData["BookReviewError"] is string reviewError && !string.IsNullOrWhiteSpace(reviewError))
            {
                <div class="alert alert-danger py-2 px-3 mb-3" role="alert">@reviewError</div>
            }

            <div class="btn-group-custom">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button type="button" class="btn-read" data-bs-toggle="modal" data-bs-target="#bookFeedbackModal">
                        Feedback
                    </button>
                }
                else
                {
                    <a class="btn-read text-decoration-none d-inline-flex align-items-center justify-content-center"
                       asp-area="Identity"
                       asp-page="/Account/Login"
                       asp-route-returnUrl="@returnUrl">
                        Feedback
                    </a>
                }
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form method="post" asp-controller="Home" asp-action="AddToCart" asp-route-bookId="@book.Id"
                          class="d-inline cart-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-cart text-decoration-none border-0">
                            <i class="bi bi-cart2 me-2"></i> Add to cart
                        </button>
                    </form>
                }
                else
                {
                    <a class="btn-cart text-decoration-none d-inline-flex align-items-center justify-content-center"
                       asp-area="Identity"
                       asp-page="/Account/Login"
                       asp-route-returnUrl="@returnUrl">
                        <i class="bi bi-cart2 me-2"></i> Add to cart
                    </a>
                }
                @if (Model.IsFavorite)
                {
                    <form method="post" asp-controller="Home" asp-action="RemoveFavorite" asp-route-bookId="@book.Id"
                          class="d-inline fav-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit" class="btn-fav-circle" aria-label="remove favorite" title="Remove favorite">
                            <i class="bi bi-heart-fill text-danger"></i>
                        </button>
                    </form>
                }
                else
                {
                    <form method="post" asp-controller="Home" asp-action="AddFavorite" asp-route-bookId="@book.Id"
                          class="d-inline fav-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit" class="btn-fav-circle" aria-label="add favorite" title="Add favorite">
                            <i class="bi bi-heart"></i>
                        </button>
                    </form>
                }
                <button type="button"
                        class="btn-share-circle"
                        data-share-url="@shareUrl"
                        data-share-title="@book.Title"
                        data-share-author="@book.Author"
                        title="Share"
                        aria-label="Share @book.Title">
                    <i class="bi bi-share"></i>
                </button>
            </div>
            <hr class="my-3 opacity-25" />

            <div class="info-bar detail-info-bar">
                <div class="info-item">Total page: @totalPages</div>
                <div class="info-item">Publish year: @publishYear</div>
                <div class="info-item">Book code: @bookCode</div>
            </div>
        </div>
    </div>

    <section class="mt-5 detail-related">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold text-navy mb-0">You might also like:</h3>
        </div>

        <div class="row row-cols-2 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3 g-md-4">
            @if (Model.RelatedBooks.Any())
            {
                @foreach (var relatedBook in Model.RelatedBooks)
                {
                    var relatedImagePath = string.IsNullOrWhiteSpace(relatedBook.ImageUrl)
                        ? Url.Content("~/images/User/Book/book2.png")
                        : Url.Content(relatedBook.ImageUrl);
                    var relatedRating = Math.Clamp(relatedBook.Rating, 0, 5);
                    var relatedIsFavorite = Model.RelatedFavoriteBookIds.Contains(relatedBook.Id);

                    <div class="col">
                        <div class="card book-card detail-related-card border-0 shadow-sm h-100 position-relative">
                            <div class="card-img-wrapper p-2">
                                <img src="@relatedImagePath" class="card-img-top rounded related-card-img" alt="@relatedBook.Title">
                            </div>
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="category-text small fw-bold">@relatedBook.CategoryName</span>
                                    @if (relatedIsFavorite)
                                    {
                                        <form method="post" asp-controller="Home" asp-action="RemoveFavorite" asp-route-bookId="@relatedBook.Id"
                                              class="d-inline related-favorite-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                                            <button type="submit" class="btn p-0 border-0 wishlist-btn active" title="Remove favorite"
                                                    aria-label="Remove @relatedBook.Title from favorites">
                                                <i class="fa-solid fa-heart text-danger"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-controller="Home" asp-action="AddFavorite" asp-route-bookId="@relatedBook.Id"
                                              class="d-inline related-favorite-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                                            <button type="submit" class="btn p-0 border-0 wishlist-btn text-secondary" title="Add favorite"
                                                    aria-label="Add @relatedBook.Title to favorites">
                                                <i class="fa-regular fa-heart"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                                <h6 class="related-book-title mb-1 small fw-bold">@relatedBook.Title</h6>
                                <p class="author-text mb-3 small italic">@relatedBook.Author</p>
                                <div class="text-end star-rating text-warning small">
                                    @for (var i = 0; i < 5; i++)
                                    {
                                        if (i < relatedRating)
                                        {
                                            <i class="fa-solid fa-star"></i>
                                        }
                                        else
                                        {
                                            <i class="fa-regular fa-star"></i>
                                        }
                                    }
                                </div>
                            </div>
                            <a asp-controller="Home" asp-action="BookDetail" asp-route-id="@relatedBook.Id"
                               class="stretched-link" aria-label="View details for @relatedBook.Title"></a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="text-muted">No related books found.</div>
                </div>
            }
        </div>
    </section>
</div>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="modal fade" id="bookFeedbackModal" tabindex="-1" aria-labelledby="bookFeedbackModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content review-modal">
                <div class="modal-body p-4 p-md-5">
                    <h2 class="review-title" id="bookFeedbackModalLabel">Your Feedback</h2>
                    <p class="review-subtitle">Please rate the quality of the book you received.</p>

                    <form method="post" asp-controller="Home" asp-action="SubmitBookReview">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookId" value="@book.Id" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <input type="hidden" name="rating" id="selectedRatingInput" value="5" />

                        <div class="review-stars" id="feedbackStars" role="group" aria-label="Book rating">
                            @for (var i = 1; i <= 5; i++)
                            {
                                <button type="button" class="star-btn active" data-rating="@i" aria-label="Rate @i star(s)">
                                    <i class="bi bi-star-fill"></i>
                                </button>
                            }
                        </div>

                        <div class="review-bottom">
                            <div class="review-user">
                                <span class="review-avatar">
                                    <i class="bi bi-person-fill"></i>
                                </span>
                                <span>@(User.Identity?.Name ?? "User")</span>
                            </div>
                            <button type="submit" class="btn-submit-review">Submit</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        (function () {
            const starsWrap = document.getElementById('feedbackStars');
            const ratingInput = document.getElementById('selectedRatingInput');
            if (starsWrap && ratingInput) {
                const starButtons = Array.from(starsWrap.querySelectorAll('.star-btn'));

                const paintStars = (rating) => {
                    starButtons.forEach((btn) => {
                        const value = Number(btn.dataset.rating || 0);
                        btn.classList.toggle('active', value <= rating);
                    });
                };

                starButtons.forEach((btn) => {
                    btn.addEventListener('click', () => {
                        const rating = Number(btn.dataset.rating || 5);
                        ratingInput.value = String(rating);
                        paintStars(rating);
                    });
                });

                paintStars(Number(ratingInput.value || 5));
            }

            const shareButton = document.querySelector('.btn-share-circle');
            if (!shareButton) return;

            const toAbsoluteUrl = (url) => {
                try {
                    return new URL(url, window.location.origin).href;
                } catch {
                    return window.location.href;
                }
            };

            const flashShareState = (titleText) => {
                const currentTitle = shareButton.getAttribute('title') || 'Share';
                shareButton.setAttribute('title', titleText);

                window.setTimeout(() => {
                    shareButton.setAttribute('title', currentTitle);
                }, 1400);
            };

            const copyToClipboard = async (text) => {
                if (navigator.clipboard && window.isSecureContext) {
                    await navigator.clipboard.writeText(text);
                    return true;
                }

                const helper = document.createElement('textarea');
                helper.value = text;
                helper.setAttribute('readonly', '');
                helper.style.position = 'fixed';
                helper.style.opacity = '0';
                document.body.appendChild(helper);
                helper.select();

                const copied = document.execCommand('copy');
                document.body.removeChild(helper);
                return copied;
            };

            shareButton.addEventListener('click', async () => {
                const shareTargetUrl = toAbsoluteUrl(shareButton.dataset.shareUrl || window.location.href);
                const shareTitle = shareButton.dataset.shareTitle || document.title;
                const shareAuthor = shareButton.dataset.shareAuthor;
                const shareText = shareAuthor ? `${shareTitle} by ${shareAuthor}` : shareTitle;

                try {
                    if (typeof navigator.share === 'function') {
                        await navigator.share({
                            title: shareTitle,
                            text: shareText,
                            url: shareTargetUrl
                        });
                        flashShareState('Shared');
                        return;
                    }

                    const copied = await copyToClipboard(shareTargetUrl);
                    flashShareState(copied ? 'Link copied' : 'Copy failed');
                } catch (error) {
                    if (error && typeof error === 'object' && 'name' in error && error.name === 'AbortError') {
                        return;
                    }

                    try {
                        const copied = await copyToClipboard(shareTargetUrl);
                        flashShareState(copied ? 'Link copied' : 'Copy failed');
                    } catch {
                        flashShareState('Copy failed');
                    }
                }
            });
        })();
    </script>
}
