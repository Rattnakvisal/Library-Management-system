@using System.Globalization
@model Library_Management_system.Models.HistoryViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "History";
}

<section class="page-bg history-page" id="historyPage">
    <div class="container page-wrap">
        <div class="d-flex align-items-center justify-content-between gap-3 mb-3 history-head">
            <h1 class="page-title mb-0">History</h1>

            <div class="summary-dropdown">
                <button class="btn btn-primary borrowing-btn" id="toggleSummary" type="button">
                    Borrowing Summary
                </button>

                <div class="summary-card shadow" id="summaryDetails">
                    <div class="summary-row">
                        <span>Sub total</span>
                        <span class="fw-bold">@Model.TotalCount</span>
                    </div>
                    <div class="summary-row">
                        <span>On hold</span>
                        <span class="fw-bold">@Model.OnHoldCount</span>
                    </div>
                    <div class="summary-row">
                        <span>Return</span>
                        <span class="fw-bold">@Model.ReturnedCount</span>
                    </div>

                    <hr class="summary-divider" />

                    <div class="summary-row mb-4">
                        <span class="small">Late return fee ($1/day):</span>
                        <span class="fw-bold">$@Model.EstimatedFine.ToString("0.00",
                                                        CultureInfo.InvariantCulture)</span>
                        </div>

                        <button type="button" class="btn btn-light w-100 fw-bold mb-2 py-2" style="color: #1e293b;">
                            Read Term and Condition
                        </button>

                        <div class="text-center">
                            <small class="gold-text">*Term and Condition Applied</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="history-list">
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        var yearText = item.Year > 0 ? item.Year.ToString(CultureInfo.InvariantCulture) : "N/A";
                        var borrowDateText = item.BorrowDate.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture);
                        var dueDateText = item.DueDate.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture);
                        var returnDateText = item.ReturnDate.HasValue
                            ? item.ReturnDate.Value.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture)
                            : "-";

                        <article class="history-card shadow-sm">
                            <div class="row g-0 align-items-center">
                                <div class="col-auto">
                                    <div class="thumb">
                                        <img src="@Url.Content(item.ImageUrl)" alt="@item.Title cover" />
                                    </div>
                                </div>

                                <div class="col">
                                    <div class="px-3 py-3">
                                        <h5 class="book-name mb-1">@item.Title</h5>
                                        <div class="small text-muted2">Author: @item.Author</div>
                                        <div class="small text-muted2">Publish Year: @yearText</div>
                                        <div class="small text-muted2">Book Code: @item.BookCode</div>

                                        <div class="stars mt-2" aria-label="Book rating">
                                            @for (var i = 0; i < 5; i++)
                                            {
                                                if (i < item.Rating)
                                                {
                                                    <i class="bi bi-star-fill"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-star"></i>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-4">
                                    <div class="status-box px-3 py-3">
                                        <div class="small">
                                            <span class="label">Status:</span>
                                            <span class="status @item.Status">@item.StatusLabel</span>
                                        </div>
                                        <div class="small text-muted2 mt-1">Borrow Date: @borrowDateText</div>
                                        <div class="small text-muted2">Due Date: @dueDateText</div>
                                        <div class="small text-muted2">Return Date: @returnDateText</div>
                                        @if (item.LateDays > 0)
                                        {
                                            <div class="small text-danger mt-1">
                                                Late @item.LateDays day(s) | Fine: $@item.FineAmount.ToString("0.00",
                                                                                CultureInfo.InvariantCulture)
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </article>
                    }
                }
                else
                {
                    <article class="history-card shadow-sm">
                        <div class="empty-state">
                            No borrowing history found yet.
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>

    @section Scripts {
        <script>
                $(function () {
                    $("#toggleSummary").on("click", function (e) {
                        e.stopPropagation();
                        $("#summaryDetails").fadeToggle(180);
                    });

                    $(document).on("click", function (e) {
                        if (!$(e.target).closest(".summary-dropdown").length) {
                            $("#summaryDetails").fadeOut(180);
                        }
                    });
                });
        </script>
    }
