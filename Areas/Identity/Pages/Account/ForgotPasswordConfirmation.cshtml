@page
@model ForgotPasswordConfirmation
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password Confirmation";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ACLEDA University Library</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Login/login.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/users/reset-password.css" asp-append-version="true" />
</head>

<body>
    <div class="container">
        <div class="card reset-card">
            <div class="left">
                <div class="logo">
                    <img src="~/images/Login/logo.png" alt="ACLEDA Logo" />
                </div>

                <div class="illustration">
                    <img src="~/images/Login/bookicon.png" alt="Books Illustration" />
                </div>
            </div>

            <div class="right">
                <h2>ACLEDA UNIVERSITY LIBRARY</h2>

                <div class="btn-login-student reset-banner">
                    <img class="logoac" src="~/images/Login/logoac.png" alt="Library Icon" />
                    OTP request submitted.
                </div>

                <section class="reset-result-card" aria-label="Forgot password confirmation">
                    <div class="reset-result-icon reset-result-icon--info">
                        <i class="bi bi-telegram" aria-hidden="true"></i>
                    </div>
                    <h3>Check Telegram for OTP</h3>
                    <p>
                        If the phone number exists, a Telegram OTP has been sent. Open the reset page and complete OTP verification.
                    </p>
                </section>

                <a asp-page="./ForgotPassword" class="btn-signin reset-action-link">
                    <span class="btn-text">Back to Forgot Password</span>
                </a>

                <div class="links reset-links">
                    <div class="forgot">
                        <a asp-page="./Login">Back to login</a>
                    </div>
                    <p>
                        Need Telegram setup help?
                        <a asp-page="./ForgotPassword">View OTP guide</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
