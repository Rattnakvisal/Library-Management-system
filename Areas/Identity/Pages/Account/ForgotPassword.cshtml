@page
@model ForgotPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot your password?";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ACLEDA University Library</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Login/login.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/users/reset-password.css" asp-append-version="true" />
</head>

<body>
    <div class="container">
        <div class="card reset-card">
            <div class="left">
                <div class="logo">
                    <img src="~/images/Login/logo.png" alt="ACLEDA Logo" />
                </div>

                <div class="illustration">
                    <img src="~/images/Login/bookicon.png" alt="Books Illustration" />
                </div>
            </div>

            <div class="right">
                <h2>ACLEDA UNIVERSITY LIBRARY</h2>

                <div class="btn-login-student reset-banner">
                    <img class="logoac" src="~/images/Login/logoac.png" alt="Library Icon" />
                    Open the OTP Telegram bot, tap Start, send your phone number, then reset here.
                </div>

                <div class="divider">
                    <span>OR</span>
                </div>

                <form method="post" class="reset-form" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="input-group">
                        <div class="icon-email">
                            <i class="fa-solid fa-phone"></i>
                        </div>
                        <input asp-for="Input.PhoneNumber"
                               type="text"
                               placeholder="Phone Number (Cambodia local or +855)"
                               autocomplete="tel"
                               aria-required="true"
                               required />
                    </div>
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>

                    <div class="input-group">
                        <div class="icon-password">
                            <i class="fa-solid fa-lock"></i>
                        </div>
                        <input asp-for="Input.Password"
                               type="password"
                               class="password"
                               placeholder="New Password"
                               autocomplete="new-password"
                               aria-required="true"
                               required />
                        <span class="toggle-password" role="button" tabindex="0" data-target="#Input_Password" aria-label="Show password">
                            <i class="bi bi-eye-slash" id="togglePassword1"></i>
                        </span>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>

                    <div class="input-group">
                        <div class="icon-password">
                            <i class="fa-solid fa-lock"></i>
                        </div>
                        <input asp-for="Input.ConfirmPassword"
                               type="password"
                               class="confirm-password"
                               placeholder="Confirm Password"
                               autocomplete="new-password"
                               aria-required="true"
                               required />
                        <span class="toggle-password" role="button" tabindex="0" data-target="#Input_ConfirmPassword" aria-label="Show password">
                            <i class="bi bi-eye-slash" id="togglePassword2"></i>
                        </span>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>

                    <button type="submit" class="btn-signin">
                        <span class="btn-text">Continue to OTP</span>
                    </button>
                </form>

                <div class="links reset-links">
                    <div class="forgot">
                        <a asp-page="./Login">Back to login</a>
                    </div>
                    <p>
                        Don’t have an account?
                        <a asp-page="./Register">Sign up</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/admin/login.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>

</html>
