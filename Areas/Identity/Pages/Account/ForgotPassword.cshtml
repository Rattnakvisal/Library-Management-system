@page
@model ForgotPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot your password?";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ACLEDA University Library</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Login/login.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/users/reset-password.css" asp-append-version="true" />
</head>

<body>
    <div class="container">
        <div class="card reset-card">
            <div class="left">
                <div class="logo">
                    <img src="~/images/Login/logo.png" alt="ACLEDA Logo" />
                </div>

                <div class="illustration">
                    <img src="~/images/Login/bookicon.png" alt="Books Illustration" />
                </div>
            </div>

            <div class="right">
                <h2>ACLEDA UNIVERSITY LIBRARY</h2>
                <section class="telegram-start-guide" aria-label="Telegram OTP setup guide">
                    <p class="telegram-start-guide__title">
                        <i class="bi bi-question-circle-fill" aria-hidden="true"></i>
                        How to reset password with Telegram OTP?
                    </p>
                    <ol class="telegram-start-guide__steps">
                        <li>Scan the QR image and open <strong>@@AUBLIBRARYCONTACT_BOT</strong> in Telegram.</li>
                        <li>Tap <strong>/start</strong>.</li>
                        <li>Send your phone number (Cambodia local or +855 format).</li>
                        <li>Submit this form, then enter OTP from Telegram on the next page.</li>
                    </ol>
                    <a class="telegram-start-guide__link" href="https://t.me/aublirarycontact_bot" target="_blank"
                           rel="noopener noreferrer">
                        <i class="bi bi-telegram" aria-hidden="true"></i>
                        Open Telegram Bot
                    </a>
                </section>
                <form method="post" class="reset-form" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="input-group">
                        <div class="icon-email">
                            <i class="fa-solid fa-phone"></i>
                        </div>
                        <input asp-for="Input.PhoneNumber" type="text"
                               placeholder="Phone Number (Cambodia local or +855)" autocomplete="tel" aria-required="true"
                               required />
                    </div>
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>

                    <div class="input-group">
                        <div class="icon-password">
                            <i class="fa-solid fa-lock"></i>
                        </div>
                        <input asp-for="Input.Password" type="password" class="password" placeholder="New Password"
                               autocomplete="new-password" aria-required="true" required />
                        <span class="toggle-password" role="button" tabindex="0" data-target="#Input_Password"
                              aria-label="Show password">
                            <i class="bi bi-eye-slash" id="togglePassword1"></i>
                        </span>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>

                    <div class="input-group">
                        <div class="icon-password">
                            <i class="fa-solid fa-lock"></i>
                        </div>
                        <input asp-for="Input.ConfirmPassword" type="password" class="confirm-password"
                               placeholder="Confirm Password" autocomplete="new-password" aria-required="true" required />
                        <span class="toggle-password" role="button" tabindex="0" data-target="#Input_ConfirmPassword"
                              aria-label="Show password">
                            <i class="bi bi-eye-slash" id="togglePassword2"></i>
                        </span>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>

                    <button type="submit" class="btn-signin">
                        <span class="btn-text">Continue to OTP</span>
                    </button>
                </form>

                <div class="links reset-links">
                    <div class="forgot">
                        <a asp-page="./Login">Back to login</a>
                    </div>
                    <p>
                        Don’t have an account?
                        <a asp-page="./Register">Sign up</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/admin/login.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>

</html>
